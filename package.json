{
  "name": "dbchat-cli",
  "version": "0.1.0",
  "private": false,
  "description": "A database-focused CLI assistant for PostgreSQL and MySQL with natural-language, SQL, schema, and explain workflows.",
  "type": "module",
  "license": "MIT",
  "author": "Codewarning",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Codewarning/dbchat-cli.git"
  },
  "homepage": "https://github.com/Codewarning/dbchat-cli#readme",
  "bugs": {
    "url": "https://github.com/Codewarning/dbchat-cli/issues"
  },

  "bin": {
    "dbchat": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "prerelease:npm:prepare": "tsc -p tsconfig.json",
    "release:npm:prepare": "node scripts/prepare-npm-package.mjs",
    "prerelease:npm:dry-run": "tsc -p tsconfig.json && node scripts/prepare-npm-package.mjs",
    "release:npm:dry-run": "npm pack .npm-package --dry-run",
    "test": "tsc -p tsconfig.json && node dist/test.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "cli",
    "database",
    "sql",
    "postgresql",
    "mysql",
    "llm",
    "ai"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ink": "^6.2.3",
    "mysql2": "^3.11.3",
    "pg": "^8.13.1",
    "react": "^19.2.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.11",
    "@types/react": "^19.2.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
