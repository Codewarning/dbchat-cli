# Project-level default configuration for local development.
# Priority order is: shell environment variables > ~/.db-chat-cli/config.json > this file > built-in code defaults.

# LLM
DBCHAT_LLM_PROVIDER=openai
DBCHAT_LLM_API_FORMAT=openai
DBCHAT_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DBCHAT_LLM_BASE_URL=https://api.openai.com/v1
DBCHAT_LLM_MODEL=gpt-5-mini

# Embeddings
DBCHAT_EMBEDDING_PROVIDER=aliyun
DBCHAT_EMBEDDING_API_KEY=
DASHSCOPE_API_KEY=
DBCHAT_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DBCHAT_EMBEDDING_MODEL=text-embedding-v4

# Result and terminal preview limits
DBCHAT_RESULT_ROW_LIMIT=200
DBCHAT_PREVIEW_ROW_LIMIT=20
DBCHAT_TEMP_ARTIFACT_RETENTION_DAYS=3
DBCHAT_INLINE_TABLE_ROW_LIMIT=5
DBCHAT_INLINE_TABLE_COLUMN_LIMIT=6
DBCHAT_PREVIEW_TABLE_ROW_LIMIT=5
DBCHAT_FORCE_HYPERLINK=true

# Context compression
DBCHAT_CONTEXT_RECENT_RAW_TURNS=3
DBCHAT_CONTEXT_RAW_HISTORY_CHARS=8000
DBCHAT_CONTEXT_LARGE_TOOL_OUTPUT_CHARS=2400
DBCHAT_CONTEXT_PERSISTED_TOOL_PREVIEW_CHARS=1200
DBCHAT_CONTEXT_MAX_TOOL_CALLS_PER_TURN=36
DBCHAT_CONTEXT_MAX_AGENT_ITERATIONS=36

# Database defaults
DBCHAT_DB_DIALECT=postgres
DBCHAT_DB_HOST=127.0.0.1
DBCHAT_DB_PORT=5432
DBCHAT_DB_NAME=postgres
DBCHAT_DB_USER=postgres
DBCHAT_DB_PASSWORD=postgres
DBCHAT_DB_SCHEMA=public
DBCHAT_DB_SSL=false
